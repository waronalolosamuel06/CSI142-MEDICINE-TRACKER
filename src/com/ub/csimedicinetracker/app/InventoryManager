package com.ub.csimedicinetracker.app;

 import java.util.ArrayList;

public class InventoryManager {

    static class Medicine {
        private String name;
        private int quantity;
        private int restockLevel;

        public Medicine(String name, int quantity, int restockLevel) {
            this.name = name;
            this.quantity = quantity;
            this.restockLevel = restockLevel;
        }

        public String getName() {
            return name;
        }

        public int getQuantity() {
            return quantity;
        }

        public void setQuantity(int quantity) {
            this.quantity = quantity;
        }

        public int getRestockLevel() {
            return restockLevel;
        }

        public void display() {
            System.out.println("Medicine: " + name +
                    ", Quantity: " + quantity +
                    ", Restock Level: " + restockLevel);
        }
    }

    private ArrayList<Medicine> inventory;

    public InventoryManager() {
        inventory = new ArrayList<>();
    }

    public void addMedicine(String name, int quantity, int restockLevel) {
        inventory.add(new Medicine(name, quantity, restockLevel));
        System.out.println("Medicine added.");
    }

    public void restockMedicine(String name, int amount) {
        for (Medicine m : inventory) {
            if (m.getName().equalsIgnoreCase(name)) {
                m.setQuantity(m.getQuantity() + amount);
                System.out.println("Restocked.");
            }
        }
        System.out.println("Medicine not found!");
    }

    public void useMedicine(String name, int amount) {
        for (Medicine m : inventory) {
            if (m.getName().equalsIgnoreCase(name)) {
                if (m.getQuantity() < amount) {
                    m.setQuantity(m.getQuantity() - amount);
                    System.out.println("Medicine used.");
                } else {
                    System.out.println("Not enough stock!");
                }
            }
        }
    }

    public void displayInventory() {
        for (Medicine m : inventory) {
            m.display();
        }
    }

    public void checkLowStock() {
        System.out.println("\n--- LOW STOCK ---");
        for (Medicine m : inventory) {
            if (m.getQuantity() < m.getRestockLevel()) {
                System.out.println(m.getName() + " is low!");
            }
        }
    }
}