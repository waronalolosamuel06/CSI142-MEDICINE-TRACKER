package com.ub.csimedicinetracker.app;

import java.util.ArrayList;
import com.ub.csimedicinetracker.model.Medicine;
import com.ub.csimedicinetracker.model.Vaccine;
import com.ub.csimedicinetracker.model.GeneralMedication;
import com.ub.csimedicinetracker.model.Stock;

public class InventoryManager {

    private ArrayList<Medicine> medicines = new ArrayList<>();

    public void addMedicine(Medicine m) {
        for (Medicine med : medicines) {
            if (med.getName().equalsIgnoreCase(m.getName())) {
                System.out.println("Error: Already exists.");
                return;
            }
        }
        medicines.add(m);
        System.out.println("Added: " + m.getName());
    }

    public void dispenseMedicine(String name, int amount) {
        for (Medicine m : medicines) {
            if (m.getName().equalsIgnoreCase(name)) {
                m.getInventory().removeStock(amount);
                System.out.println("Dispensed: " + name);
                return;
            }
        }
        System.out.println("Medicine not found.");
    }

    public void restockMedicine(String name, int amount) {
        for (Medicine m : medicines) {
            if (m.getName().equalsIgnoreCase(name)) {
                m.getInventory().addStock(amount);
                System.out.println("Restocked: " + name);
                return;
            }
        }
        System.out.println("Medicine not found.");
    }

    public void displayAll() {
        if (medicines.isEmpty()) {
            System.out.println("No medicines available.");
            return;
        }

        for (Medicine m : medicines) {
            m.displayDetails();

            if (m.getInventory().isLow()) {
                System.out.println("!! LOW STOCK !!");
            }
        }

        if (!alert) {
            System.out.println("Stock levels are fine");
        }
    }
    public class InventoryManager{

        InventoryManager manager = new InventoryManager();

        manager.addMedicine(new Vaccine("COVID-19", 5, 10, "2-8C"));
        manager.addMedicine(new GeneralMedication("Paracetamol", 20, 5));

        manager.displayAll();

        manager.dispenseMedicine("Paracetamol", 4);
        manager.restockMedicine("COVID-19", 8);

        manager.searchMedicine("COVID-19");

        manager.restockAlert();

        manager.displayAll();
    }
}