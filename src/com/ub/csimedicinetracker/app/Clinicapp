package com.ub.csimedicinetracker.app;

import java.util.Scanner;

public class Clinicapp {
    public static void main(String[] args) {
        Scanner in = new Scanner(System.in);
        boolean running = true;

        while (running) {
            System.out.println("\n--- CLINIC INVENTORY SYSTEM ---");
            System.out.println("1. Add New Medicine");
            System.out.println("2. View Current Inventory");
            System.out.println("3. Search for Specific Item");
            System.out.println("4. Exit");
            System.out.print("Select an option: ");

            int choice = in.nextInt();
            in.nextLine(); // Clear the buffer

            switch (choice) {
                case 1:
                    System.out.print("Enter medicine name: ");
                    String name = in.nextLine();
                    System.out.println("[System] " + name + " added successfully.");
                    break;

                case 2:
                    System.out.println("\n--- Displaying Inventory ---");
                    // Logic to list items from your InventoryManager
                    break;

                case 3:
                    System.out.print("Enter item name to search: ");
                    String searchName = in.nextLine();
                    System.out.println("Searching for: " + searchName + "...");
                    break;

                case 4:
                    System.out.println("Exiting gracefully... Goodbye!");
                    running = false;
                    break;

                default:
                    System.out.println("Invalid choice. Please try again.");
            }
        }
        in.close();
    
}

    
}
